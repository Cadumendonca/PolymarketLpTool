PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=2

# Ajustes opcionais do bot (veja passive_liquidity/config_manager.py)
# PASSIVE_BASE_SIZE=10
# PASSIVE_LOOP_INTERVAL=2
# PASSIVE_MAX_QUOTE_TASKS=30
# PASSIVE_QUOTE_ALL_TOKENS=true

# Máximo de linhas para exibir no catálogo ao iniciar (0 ou vazio = sem limite)
# PASSIVE_CATALOG_MAX_ROWS=300
# Tamanho da página no catálogo interativo
# PASSIVE_CATALOG_PAGE_SIZE=25

TELEGRAM_TOTAL_DEPOSITED_USDC=
# Notificações do Telegram: Insira o Bot Token e o Chat ID abaixo
# (Obtenha o token com o @BotFather; o Chat ID pode ser obtido com @userinfobot, geralmente é um número negativo como -100xxxxxxxxxx)
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ACCOUNT_LABEL=ContaPolymarket1
TELEGRAM_NOTIFY_COOLDOWN_SEC=30

# =============================================================================
# Monitoramento Passivo de Alertas de Risco (Execução / Profundidade)
# Profundidade: Aciona se depth_ratio > PASSIVE_ALERT_DEPTH_RATIO_THRESHOLD (padrão 0.15 = 15%)
# Execução (Fill): Aciona se qualquer condição for atendida
# =============================================================================
PASSIVE_ALERT_MONITORING=false
# Notificar no Telegram quando ordens forem parcial ou totalmente executadas (Evento: Ordem Executada)
# Independente de PASSIVE_ALERT_MONITORING
PASSIVE_TELEGRAM_NOTIFY_FILL=true
PASSIVE_TELEGRAM_NOTIFY_PARTIAL_FILL=false
PASSIVE_TELEGRAM_NOTIFY_FULL_FILL=false
PASSIVE_ALERT_COOLDOWN_SEC=120
PASSIVE_MONITOR_SHORT_TRADE_LOOKBACK_SEC=180 
PASSIVE_ALERT_FILL_RATE_THRESHOLD=0.35
PASSIVE_ALERT_SHORT_TRADES_THRESHOLD=8
PASSIVE_ALERT_FILL_RISK_SCORE_THRESHOLD=0.45
PASSIVE_ALERT_DIRECTION_IMBALANCE_MIN=0.62
PASSIVE_ALERT_DEPTH_RATIO_THRESHOLD=0.7
PASSIVE_ALERT_SIG_FILL_RATE_DELTA=0.08
PASSIVE_ALERT_SIG_SHORT_TRADES_DELTA=4
PASSIVE_ALERT_SIG_FILL_RISK_DELTA=0.08
PASSIVE_ALERT_SIG_ADVERSE_SHARE_DELTA=0.07
PASSIVE_ALERT_SIG_DEPTH_RATIO_DELTA=0.05

# Janela longa para cálculo de taxa de execução (relacionado aos alertas de risco)
PASSIVE_FILL_LOOKBACK_SEC=3600
PASSIVE_FILL_DENOM=25

# Intervalo para atualizar a whitelist com base nas ordens abertas (segundos)
# Apenas se PASSIVE_TOKEN_WHITELIST não estiver configurado
PASSIVE_WHITELIST_REFRESH_SEC=120

# -----------------------------------------------------------------------------
# Ajuste de Preço Padrão: Se true, ordens sem regras salvas no Telegram usarão
# as configurações PASSIVE_CUSTOM_* abaixo (estratégias nativas serão ignoradas)
PASSIVE_DEFAULT_CUSTOM_PRICING=true
# Ajuste Personalizado Opcional: Apenas se o item anterior for false, apenas as 
# ordens listadas aqui usarão os ajustes personalizados PASSIVE_CUSTOM_*
# IDs das ordens separados por vírgula
# PASSIVE_CUSTOM_ORDER_IDS=

# Ajuste Personalizado para Tick Grosso (Coarse): N é a posição na banda de incentivo
# Exemplo COMPRA níveis [0.28, 0.27, 0.26]: N=1 -> 0.28, N=2 -> 0.27
PASSIVE_CUSTOM_COARSE_TICK_OFFSET=3
PASSIVE_CUSTOM_COARSE_ALLOW_TOP_OF_BOOK=true
PASSIVE_CUSTOM_COARSE_MIN_CANDIDATES=3

# Ajuste Personalizado para Tick Fino (Fine): Faixas de segurança e alvo
PASSIVE_CUSTOM_FINE_SAFE_MIN=0.1
PASSIVE_CUSTOM_FINE_SAFE_MAX=0.9
PASSIVE_CUSTOM_FINE_TARGET_RATIO=0.5
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Painel Web (Opcional): Veja status, ordens, PnL e edite regras JSON no navegador
# Recomenda-se usar um WEB_PANEL_TOKEN forte e aleatório. Por padrão, escuta apenas no localhost.
WEB_PANEL_TOKEN=troque_esta_senha
WEB_PANEL_HOST=127.0.0.1
WEB_PANEL_PORT=8888
# WEB_PANEL_SECRET_KEY=
# Para iniciar: python run_web_panel.py
# -----------------------------------------------------------------------------
