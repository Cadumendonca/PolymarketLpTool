# Credentials / Credenciais
PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=2

# Optional Bot Settings / Ajustes Opcionais do Bot
# PASSIVE_BASE_SIZE=10
# PASSIVE_LOOP_INTERVAL=2
# PASSIVE_MAX_QUOTE_TASKS=30
# PASSIVE_QUOTE_ALL_TOKENS=true

# Interactive Catalog Settings / Configurações do Catálogo Interativo
# PASSIVE_CATALOG_MAX_ROWS=300
# PASSIVE_CATALOG_PAGE_SIZE=25

# Telegram Notifications / Notificações do Telegram
# Bot Token from @BotFather; Chat ID from @userinfobot (usually -100xxxxxxxxxx)
# Token do Bot via @BotFather; Chat ID via @userinfobot (geralmente -100xxxxxxxxxx)
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ACCOUNT_LABEL=PolymarketAccount1
TELEGRAM_NOTIFY_COOLDOWN_SEC=30
TELEGRAM_TOTAL_DEPOSITED_USDC=

# =============================================================================
# Risk Alerts (Execution / Depth) / Alertas de Risco (Execução / Profundidade)
# =============================================================================
PASSIVE_ALERT_MONITORING=false
# Notify on Telegram for partial/full fills / Notificar no Telegram para execuções parciais/totais
PASSIVE_TELEGRAM_NOTIFY_FILL=true
PASSIVE_TELEGRAM_NOTIFY_PARTIAL_FILL=false
PASSIVE_TELEGRAM_NOTIFY_FULL_FILL=false
PASSIVE_ALERT_COOLDOWN_SEC=120
PASSIVE_MONITOR_SHORT_TRADE_LOOKBACK_SEC=180 
PASSIVE_ALERT_FILL_RATE_THRESHOLD=0.35
PASSIVE_ALERT_SHORT_TRADES_THRESHOLD=8
PASSIVE_ALERT_FILL_RISK_SCORE_THRESHOLD=0.45
PASSIVE_ALERT_DIRECTION_IMBALANCE_MIN=0.62
PASSIVE_ALERT_DEPTH_RATIO_THRESHOLD=0.7
PASSIVE_ALERT_SIG_FILL_RATE_DELTA=0.08
PASSIVE_ALERT_SIG_SHORT_TRADES_DELTA=4
PASSIVE_ALERT_SIG_FILL_RISK_DELTA=0.08
PASSIVE_ALERT_SIG_ADVERSE_SHARE_DELTA=0.07
PASSIVE_ALERT_SIG_DEPTH_RATIO_DELTA=0.05

# Fill rate lookback / Janela de cálculo da taxa de execução
PASSIVE_FILL_LOOKBACK_SEC=3600
PASSIVE_FILL_DENOM=25

# Whitelist refresh interval / Intervalo de atualização da whitelist (seconds)
PASSIVE_WHITELIST_REFRESH_SEC=120

# -----------------------------------------------------------------------------
# Pricing Logic / Lógica de Precificação
# If true, all orders use PASSIVE_CUSTOM_* settings / Se true, usa ajustes PASSIVE_CUSTOM_*
PASSIVE_DEFAULT_CUSTOM_PRICING=true
# Optional: specific IDs to use custom pricing / IDs específicos para ajuste personalizado
# PASSIVE_CUSTOM_ORDER_IDS=

# Custom Pricing: Coarse Tick / Ajuste Personalizado: Tick Grosso
# N is the rank in the reward band / N é a posição na banda de recompensa
PASSIVE_CUSTOM_COARSE_TICK_OFFSET=3
PASSIVE_CUSTOM_COARSE_ALLOW_TOP_OF_BOOK=true
PASSIVE_CUSTOM_COARSE_MIN_CANDIDATES=3

# Custom Pricing: Fine Tick / Ajuste Personalizado: Tick Fino
PASSIVE_CUSTOM_FINE_SAFE_MIN=0.1
PASSIVE_CUSTOM_FINE_SAFE_MAX=0.9
PASSIVE_CUSTOM_FINE_TARGET_RATIO=0.5
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Web Panel / Painel Web (Optional)
# Use a strong WEB_PANEL_TOKEN. Listens on localhost by default.
# Use um WEB_PANEL_TOKEN forte. Escuta no localhost por padrão.
WEB_PANEL_TOKEN=change_this_password
WEB_PANEL_HOST=127.0.0.1
WEB_PANEL_PORT=8888
# WEB_PANEL_SECRET_KEY=
# To start: python run_web_panel.py
# -----------------------------------------------------------------------------
